{
  "name": "lms",
  "version": "1.0.0",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "@types/bun": "1.3.10",
      "oxfmt": "0.40.0",
      "oxlint": "1.55.0",
      "tailwindcss": "4.2.1",
      "typescript": "5.9.3",
      "zod": "4.3.6"
    }
  },
  "type": "module",
  "scripts": {
    "dev:web": "bun --filter @lms/web dev",
    "dev:api": "bun --filter @lms/api dev",
    "dev": "concurrently 'bun run dev:web'"
  }
}
